# Copy this file to .env and fill in a funded test-wallet private key plus the
# RPC URL for the network you want to use. Never commit .env.

# Signing account. Prefer a funded test wallet, not a main wallet.
PRIVATE_KEY=0xyour_private_key_without_quotes

# Sepolia
SEPOLIA_RPC_URL=https://sepolia.infura.io/v3/YOUR_PROJECT_ID

# Holesky
HOLESKY_RPC_URL=https://ethereum-holesky-rpc.publicnode.com

# Any other EVM chain
CUSTOM_RPC_URL=https://your-rpc-url.example

# Optional, for Etherscan verification with forge verify-contract.
ETHERSCAN_API_KEY=your_etherscan_api_key
